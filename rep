      {/* IMPACT TAB */}
      {tab === "impact" && (
        <div>
          {[
            { icon: "🌊", title: "Ocean Pollution", stat: "8M tons", desc: "of plastic enter oceans every year. Proper disposal can prevent this." },
            { icon: "🌡️", title: "Methane Emissions", stat: "5% of GHGs", desc: "come from landfills. Composting wet waste reduces emissions significantly." },
            { icon: "💧", title: "Groundwater", stat: "50% at risk", desc: "of groundwater sources are threatened by improper hazardous waste disposal." },
            { icon: "♻️", title: "Recycling Benefit", stat: "95% energy saved", desc: "when recycling aluminum vs. producing from raw materials." },
          ].map(fact => (
            <div key={fact.title} className="card" style={{ marginBottom: 14, display: "flex", gap: 16, alignItems: "flex-start" }}>
              <div style={{ width: 52, height: 52, background: "#eaf4eb", borderRadius: 14, display: "flex", alignItems: "center", justifyContent: "center", fontSize: 26, flexShrink: 0 }}>{fact.icon}</div>
              <div>
                <div style={{ fontSize: 14, fontWeight: 700, color: "#1a3d1f", marginBottom: 2 }}>{fact.title}</div>
                <div style={{ fontSize: 18, fontWeight: 700, color: "#2d7a3a", marginBottom: 4 }}>{fact.stat}</div>
                <div style={{ fontSize: 12, color: "#7a9a7a", lineHeight: 1.5 }}>{fact.desc}</div>
              </div>
            </div>
          ))}

          <div className="card" style={{ background: "linear-gradient(135deg, #1a3d1f, #2d7a3a)", marginTop: 8 }}>
            <h3 style={{ color: "white", fontSize: 15, fontWeight: 700, marginBottom: 8 }}>Your Potential Impact</h3>
            <p style={{ color: "#c5e8c8", fontSize: 13, lineHeight: 1.6 }}>If every student on campus recycled just 500g per week, we could collectively divert over 2 tonnes of waste from landfills every month. Start your contribution today!</p>
          </div>
        </div>
      )}
    </div>
  );
}

// ─── PROFILE PAGE ──────────────────────────────────────────────────────────
function ProfilePage({ currentUser, users, logs, logout, setPage }) {
  if (!currentUser) return null;
  const userLogs = logs.filter(l => l.userId === currentUser.id);
  const totalWaste = userLogs.reduce((s, l) => s + l.weightGrams, 0);
  const rank = [...users].sort((a, b) => b.points - a.points).findIndex(u => u.id === currentUser.id) + 1;
  const level = currentUser.points < 100 ? { name: "Eco Newcomer", icon: "🌱", next: 100 } : currentUser.points < 300 ? { name: "Green Warrior", icon: "🌿", next: 300 } : currentUser.points < 600 ? { name: "Eco Champion", icon: "🌳", next: 600 } : { name: "Planet Guardian", icon: "🌍", next: 1000 };

  return (
    <div className="slide-up" style={{ padding: "20px 16px" }}>
      {/* Profile Card */}
      <div className="card" style={{ background: "linear-gradient(135deg, #1a3d1f, #2d7a3a)", marginBottom: 20 }}>
        <div style={{ display: "flex", alignItems: "center", gap: 16, marginBottom: 20 }}>
          <div className="avatar" style={{ width: 60, height: 60, fontSize: 20, background: "rgba(255,255,255,0.2)", border: "2px solid rgba(255,255,255,0.3)" }}>{currentUser.avatar}</div>
          <div>
            <div style={{ fontSize: 18, fontWeight: 700, color: "white" }}>{currentUser.name}</div>
            <div style={{ fontSize: 12, color: "#c5e8c8" }}>{currentUser.email}</div>
            <div style={{ fontSize: 12, color: "#a8e6b0", marginTop: 4 }}>🏅 Rank #{rank} on campus</div>
          </div>
        </div>
        <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: 12 }}>
          {[["⭐ Points", currentUser.points], ["♻️ kg Recycled", (totalWaste / 1000).toFixed(1)], ["📊 Logs", userLogs.length]].map(([k, v]) => (
            <div key={k} style={{ background: "rgba(255,255,255,0.12)", borderRadius: 12, padding: "12px 8px", textAlign: "center" }}>
              <div style={{ fontSize: 18, fontWeight: 700, color: "white" }}>{v}</div>
              <div style={{ fontSize: 10, color: "#c5e8c8", marginTop: 2 }}>{k}</div>
            </div>
          ))}
        </div>
      </div>

      {/* Level Progress */}
      <div className="card" style={{ marginBottom: 20 }}>
        <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 10 }}>
          <div>
            <span style={{ fontSize: 24 }}>{level.icon}</span>
            <span style={{ fontSize: 15, fontWeight: 700, color: "#1a3d1f", marginLeft: 8 }}>{level.name}</span>
          </div>
          <span style={{ fontSize: 12, color: "#7a9a7a" }}>{currentUser.points}/{level.next} pts</span>
        </div>
        <div className="progress-bar"><div className="progress-fill" style={{ width: `${Math.min(100, (currentUser.points / level.next) * 100)}%` }} /></div>
        <div style={{ fontSize: 11, color: "#7a9a7a", marginTop: 6 }}>{level.next - currentUser.points} pts to next level</div>
      </div>

      {/* Recent Activity */}
      <div className="card" style={{ marginBottom: 20 }}>
        <h3 style={{ fontSize: 14, fontWeight: 700, color: "#1a3d1f", marginBottom: 14 }}>Recent Activity</h3>
        {userLogs.length === 0 && <p style={{ fontSize: 13, color: "#7a9a7a" }}>No disposal logs yet. Start recycling to earn points!</p>}
        {userLogs.slice(0, 5).map(l => {
          const wt = WASTE_TYPES.find(w => w.id === l.wasteType);
          return (
            <div key={l.id} style={{ display: "flex", alignItems: "center", gap: 12, padding: "10px 0", borderBottom: "1px solid #f0f5f0" }}>
              <span style={{ fontSize: 22 }}>{wt?.icon}</span>
              <div style={{ flex: 1 }}>
                <div style={{ fontSize: 13, fontWeight: 600, color: "#1a3d1f" }}>{wt?.label} — {l.weightGrams}g</div>
                <div style={{ fontSize: 11, color: "#7a9a7a" }}>{new Date(l.timestamp).toLocaleDateString()}</div>
              </div>
              <span style={{ fontSize: 13, fontWeight: 700, color: "#2d7a3a" }}>+{l.points}</span>
            </div>
          );
        })}
      </div>

      <button className="eco-btn" onClick={() => setPage("rewards")} style={{ width: "100%", marginBottom: 12, textAlign: "center" }}>🎁 View Rewards</button>
      <button className="eco-btn outline" onClick={logout} style={{ width: "100%", textAlign: "center" }}>Sign Out</button>
    </div>
  );
}

// ─── ADMIN PAGE ─────────────────────────────────────────────────────────────
function AdminPage({ users, setUsers, logs, rewards, setRewards, currentUser, setCurrentUser, showToast }) {
  const [tab, setTab] = useState("users");
  const [editPoints, setEditPoints] = useState({});
  const [newReward, setNewReward] = useState({ name: "", points: "", icon: "🎁", category: "Food", stock: 10 });
  const [editingReward, setEditingReward] = useState(null);

  const adjustPoints = (userId, delta) => {
    setUsers(us => us.map(u => u.id === userId ? { ...u, points: Math.max(0, u.points + delta) } : u));
    if (currentUser?.id === userId) setCurrentUser(cu => ({ ...cu, points: Math.max(0, cu.points + delta) }));
    showToast(`Points adjusted by ${delta > 0 ? "+" : ""}${delta}`);
  };

  const addReward = () => {
    if (!newReward.name || !newReward.points) return;
    setRewards(rs => [...rs, { id: genId(), ...newReward, points: parseInt(newReward.points), stock: parseInt(newReward.stock) }]);
    setNewReward({ name: "", points: "", icon: "🎁", category: "Food", stock: 10 });
    showToast("Reward added!");
  };

  const removeReward = (id) => { setRewards(rs => rs.filter(r => r.id !== id)); showToast("Reward removed."); };

  const tabs = [
    { id: "users", label: "👥 Users" },
    { id: "logs", label: "📋 Logs" },
    { id: "rewards", label: "🎁 Rewards" },
  ];

  return (
    <div className="slide-up" style={{ padding: "20px 16px" }}>
      <div style={{ display: "flex", alignItems: "center", gap: 12, marginBottom: 20 }}>
        <div style={{ background: "#e24b4a20", borderRadius: 10, padding: "6px 10px" }}>⚙️</div>
        <div>
          <h2 style={{ fontFamily: "'Space Grotesk', sans-serif", fontSize: 20, fontWeight: 700, color: "#1a3d1f" }}>Admin Panel</h2>
          <div style={{ fontSize: 11, color: "#7a9a7a" }}>Manage users, logs & rewards</div>
        </div>
      </div>

      <div style={{ display: "flex", gap: 8, marginBottom: 20, background: "white", padding: "6px", borderRadius: 16 }}>
        {tabs.map(t => (
          <button key={t.id} onClick={() => setTab(t.id)} style={{ flex: 1, padding: "8px 0", borderRadius: 10, background: tab === t.id ? "#2d7a3a" : "transparent", color: tab === t.id ? "white" : "#7a9a7a", border: "none", fontSize: 11, fontWeight: 700, cursor: "pointer" }}>{t.label}</button>
        ))}
      </div>

      {tab === "users" && (
        <div>
          {users.sort((a, b) => b.points - a.points).map(u => (
            <div key={u.id} className="card" style={{ marginBottom: 12, padding: "14px 16px" }}>
              <div style={{ display: "flex", alignItems: "center", gap: 12, marginBottom: 12 }}>
                <div className="avatar" style={{ background: "#2d7a3a", fontSize: 11 }}>{u.avatar}</div>
                <div style={{ flex: 1 }}>
                  <div style={{ fontSize: 14, fontWeight: 700, color: "#1a3d1f" }}>{u.name}</div>
                  <div style={{ fontSize: 11, color: "#7a9a7a" }}>{u.email}</div>
                </div>
                <div style={{ fontSize: 16, fontWeight: 700, color: "#2d7a3a" }}>⭐ {u.points}</div>
              </div>
              <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: 8 }}>
                <input type="number" placeholder="Manual pts" value={editPoints[u.id] || ""} onChange={e => setEditPoints(ep => ({ ...ep, [u.id]: e.target.value }))} style={{ padding: "8px 10px", fontSize: 12 }} />
                <button onClick={() => { if (editPoints[u.id]) { adjustPoints(u.id, parseInt(editPoints[u.id])); setEditPoints(ep => ({ ...ep, [u.id]: "" })); } }} style={{ background: "#2d7a3a", color: "white", borderRadius: 8, padding: "8px", fontSize: 12, fontWeight: 600 }}>Add</button>
                <button onClick={() => { if (editPoints[u.id]) { adjustPoints(u.id, -parseInt(editPoints[u.id])); setEditPoints(ep => ({ ...ep, [u.id]: "" })); } }} style={{ background: "#e24b4a", color: "white", borderRadius: 8, padding: "8px", fontSize: 12, fontWeight: 600 }}>Deduct</button>
              </div>
            </div>
          ))}
        </div>
      )}

      {tab === "logs" && (
        <div>
          <div style={{ display: "flex", gap: 10, marginBottom: 14, flexWrap: "wrap" }}>
            <div className="card" style={{ flex: "1", minWidth: 80, textAlign: "center", padding: "12px 8px" }}><div style={{ fontSize: 20, fontWeight: 700, color: "#2d7a3a" }}>{logs.length}</div><div style={{ fontSize: 10, color: "#7a9a7a" }}>Total Logs</div></div>
            <div className="card" style={{ flex: "1", minWidth: 80, textAlign: "center", padding: "12px 8px" }}><div style={{ fontSize: 20, fontWeight: 700, color: "#2d7a3a" }}>{(logs.reduce((s, l) => s + l.weightGrams, 0) / 1000).toFixed(1)}kg</div><div style={{ fontSize: 10, color: "#7a9a7a" }}>Total Waste</div></div>
            <div className="card" style={{ flex: "1", minWidth: 80, textAlign: "center", padding: "12px 8px" }}><div style={{ fontSize: 20, fontWeight: 700, color: "#2d7a3a" }}>{logs.reduce((s, l) => s + l.points, 0)}</div><div style={{ fontSize: 10, color: "#7a9a7a" }}>Pts Awarded</div></div>
          </div>
          {logs.slice(0, 15).map(l => {
            const user = users.find(u => u.id === l.userId);
            const wt = WASTE_TYPES.find(w => w.id === l.wasteType);
            return (
              <div key={l.id} style={{ display: "flex", alignItems: "center", gap: 10, padding: "10px 14px", background: "white", borderRadius: 12, marginBottom: 8, fontSize: 13 }}>
                <span style={{ fontSize: 18 }}>{wt?.icon}</span>
                <div style={{ flex: 1 }}>
                  <span style={{ fontWeight: 600, color: "#1a3d1f" }}>{user?.name?.split(" ")[0] || "?"}</span>
                  <span style={{ color: "#7a9a7a" }}> · {wt?.label} · {l.weightGrams}g</span>
                </div>
                <span style={{ fontWeight: 700, color: "#2d7a3a", fontSize: 12 }}>+{l.points}</span>
              </div>
            );
          })}
        </div>
      )}

      {tab === "rewards" && (
        <div>
          {/* Add Reward Form */}
          <div className="card" style={{ marginBottom: 20 }}>
            <h3 style={{ fontSize: 14, fontWeight: 700, color: "#1a3d1f", marginBottom: 14 }}>Add New Reward</h3>
            <input type="text" placeholder="Reward name" value={newReward.name} onChange={e => setNewReward(r => ({ ...r, name: e.target.value }))} style={{ marginBottom: 10 }} />
            <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 10, marginBottom: 10 }}>
              <input type="number" placeholder="Points required" value={newReward.points} onChange={e => setNewReward(r => ({ ...r, points: e.target.value }))} />
              <input type="number" placeholder="Stock" value={newReward.stock} onChange={e => setNewReward(r => ({ ...r, stock: e.target.value }))} />
            </div>
            <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 10, marginBottom: 14 }}>
              <input type="text" placeholder="Icon (emoji)" value={newReward.icon} onChange={e => setNewReward(r => ({ ...r, icon: e.target.value }))} />
              <select value={newReward.category} onChange={e => setNewReward(r => ({ ...r, category: e.target.value }))}>
                {["Food", "Voucher", "Gift"].map(c => <option key={c}>{c}</option>)}
              </select>
            </div>
            <button className="eco-btn" onClick={addReward} style={{ width: "100%", textAlign: "center", fontSize: 13 }}>+ Add Reward</button>
          </div>

          {rewards.map(r => (
            <div key={r.id} className="card" style={{ marginBottom: 10, display: "flex", alignItems: "center", gap: 12 }}>
              <span style={{ fontSize: 28 }}>{r.icon}</span>
              <div style={{ flex: 1 }}>
                <div style={{ fontSize: 13, fontWeight: 700, color: "#1a3d1f" }}>{r.name}</div>
                <div style={{ fontSize: 11, color: "#7a9a7a" }}>⭐ {r.points} pts · {r.stock} in stock</div>
              </div>
              <button onClick={() => removeReward(r.id)} style={{ background: "#fdf0f0", color: "#e24b4a", border: "none", borderRadius: 8, padding: "6px 10px", fontSize: 12, fontWeight: 600 }}>Remove</button>
            </div>
          ))}
        </div>
      )}
    </div>
  );
}
