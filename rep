  );
}

// ─── DISPOSE PAGE ──────────────────────────────────────────────────────────
function DisposePage({ currentUser, setPage, setAuthMode, submitDisposal, logs }) {
  const [wasteType, setWasteType] = useState("dry");
  const [weight, setWeight] = useState("");
  const [submitted, setSubmitted] = useState(false);
  const [lastPoints, setLastPoints] = useState(0);

  if (!currentUser) {
    return (
      <div style={{ padding: "60px 24px", textAlign: "center" }} className="slide-up">
        <div style={{ fontSize: 60, marginBottom: 20 }}>📱</div>
        <h2 style={{ fontSize: 22, fontWeight: 700, color: "#1a3d1f", marginBottom: 12 }}>Scan & Earn Points</h2>
        <p style={{ color: "#7a9a7a", fontSize: 14, marginBottom: 28, lineHeight: 1.6 }}>Sign in to log your waste disposal and start earning green reward points.</p>
        <button className="eco-btn" onClick={() => { setAuthMode("login"); setPage("auth"); }} style={{ marginBottom: 12, display: "block", width: "100%" }}>Sign In to Continue</button>
        <button className="eco-btn outline" onClick={() => { setAuthMode("signup"); setPage("auth"); }} style={{ display: "block", width: "100%" }}>Create Free Account</button>
      </div>
    );
  }

  const today = new Date().toISOString().slice(0, 10);
  const todayLogs = logs.filter(l => l.userId === currentUser.id && l.timestamp.startsWith(today));
  const remaining = MAX_DAILY_SUBMISSIONS - todayLogs.length;
  const estPoints = weight ? calcPoints(parseInt(weight) || 0) : 0;

  const handleSubmit = () => {
    const w = parseInt(weight);
    if (!w || w <= 0) return;
    const pts = calcPoints(w);
    const success = submitDisposal(wasteType, w);
    if (success) { setLastPoints(pts); setSubmitted(true); setWeight(""); }
  };

  if (submitted) {
    return (
      <div style={{ padding: "40px 24px", textAlign: "center" }} className="slide-up">
        <div style={{ width: 100, height: 100, background: "#eaf4eb", borderRadius: "50%", display: "flex", alignItems: "center", justifyContent: "center", fontSize: 50, margin: "0 auto 24px" }}>✅</div>
        <h2 style={{ fontFamily: "'Space Grotesk', sans-serif", fontSize: 26, fontWeight: 700, color: "#1a3d1f", marginBottom: 8 }}>Great Job!</h2>
        <div style={{ fontSize: 40, fontWeight: 700, color: "#2d7a3a", marginBottom: 8 }}>+{lastPoints} pts</div>
        <p style={{ color: "#7a9a7a", fontSize: 14, marginBottom: 28 }}>You've earned {lastPoints} points for responsible waste disposal 🌿</p>
        <button className="eco-btn" onClick={() => setSubmitted(false)} style={{ marginBottom: 12, display: "block", width: "100%" }}>Log Another</button>
        <button className="eco-btn outline" onClick={() => setPage("rewards")} style={{ display: "block", width: "100%" }}>View Rewards</button>
      </div>
    );
  }

  return (
    <div className="slide-up" style={{ padding: "20px 16px" }}>
      <h2 style={{ fontFamily: "'Space Grotesk', sans-serif", fontSize: 22, fontWeight: 700, color: "#1a3d1f", marginBottom: 4 }}>Log Disposal ♻️</h2>
      <p style={{ color: "#7a9a7a", fontSize: 13, marginBottom: 20 }}>You have {remaining} submission{remaining !== 1 ? "s" : ""} remaining today</p>

      {/* Remaining bar */}
      <div className="card" style={{ marginBottom: 20, padding: "16px" }}>
        <div style={{ display: "flex", justifyContent: "space-between", marginBottom: 8 }}>
          <span style={{ fontSize: 12, color: "#7a9a7a", fontWeight: 600 }}>Daily Limit</span>
          <span style={{ fontSize: 12, fontWeight: 700, color: remaining > 0 ? "#2d7a3a" : "#e24b4a" }}>{todayLogs.length}/{MAX_DAILY_SUBMISSIONS}</span>
        </div>
        <div className="progress-bar"><div className="progress-fill" style={{ width: `${(todayLogs.length / MAX_DAILY_SUBMISSIONS) * 100}%`, background: remaining > 0 ? undefined : "#e24b4a" }} /></div>
      </div>

      {/* Waste Type */}
      <div style={{ marginBottom: 20 }}>
        <label style={{ fontSize: 12, fontWeight: 700, color: "#5a7a5a", display: "block", marginBottom: 10, textTransform: "uppercase", letterSpacing: 0.5 }}>Select Waste Type</label>
        <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: 10 }}>
          {WASTE_TYPES.map(wt => (
            <div key={wt.id} className={`waste-chip ${wasteType === wt.id ? "selected" : ""}`} onClick={() => setWasteType(wt.id)} style={{ textAlign: "center" }}>
              <div style={{ fontSize: 28, marginBottom: 4 }}>{wt.icon}</div>
              <div style={{ fontSize: 12, fontWeight: 600, color: "#1a3d1f" }}>{wt.label}</div>
              <div style={{ fontSize: 10, color: "#7a9a7a", marginTop: 2 }}>{wt.desc}</div>
            </div>
          ))}
        </div>
      </div>

      {/* Weight Input */}
      <div className="card" style={{ marginBottom: 20 }}>
        <label style={{ fontSize: 12, fontWeight: 700, color: "#5a7a5a", display: "block", marginBottom: 10, textTransform: "uppercase", letterSpacing: 0.5 }}>Weight (grams)</label>
        <input type="number" placeholder="e.g. 500" value={weight} onChange={e => setWeight(e.target.value)} min={1} max={MAX_WEIGHT_GRAMS} />
        <div style={{ display: "flex", justifyContent: "space-between", marginTop: 10 }}>
          <span style={{ fontSize: 11, color: "#aaa" }}>Max: {MAX_WEIGHT_GRAMS}g per entry</span>
          {estPoints > 0 && <span style={{ fontSize: 12, fontWeight: 700, color: "#2d7a3a" }}>~{estPoints} pts to earn</span>}
        </div>
        <div style={{ display: "flex", gap: 8, marginTop: 12 }}>
          {[100, 250, 500, 1000].map(g => (
            <button key={g} onClick={() => setWeight(g)} style={{ flex: 1, background: weight == g ? "#2d7a3a" : "#f0f7f0", color: weight == g ? "white" : "#2d7a3a", border: "1.5px solid #c5e0c5", borderRadius: 8, padding: "6px 0", fontSize: 12, fontWeight: 600 }}>{g}g</button>
          ))}
        </div>
      </div>

      {/* Tip */}
      <div style={{ background: "#fffbf0", border: "1px solid #f0e0aa", borderRadius: 12, padding: "12px 14px", marginBottom: 20, display: "flex", gap: 10 }}>
        <span>💡</span>
        <span style={{ fontSize: 12, color: "#7a5a1a", lineHeight: 1.5 }}>{AWARENESS_TIPS[Math.floor(Math.random() * AWARENESS_TIPS.length)]}</span>
      </div>

      <button className="eco-btn" onClick={handleSubmit} disabled={remaining === 0 || !weight} style={{ width: "100%", textAlign: "center", opacity: (remaining === 0 || !weight) ? 0.5 : 1 }}>
        {remaining === 0 ? "Daily Limit Reached" : "Submit Disposal"}
      </button>

      {/* Today's logs */}
      {todayLogs.length > 0 && (
        <div style={{ marginTop: 24 }}>
          <h3 style={{ fontSize: 14, fontWeight: 700, color: "#1a3d1f", marginBottom: 12 }}>Today's Submissions</h3>
          {todayLogs.map(l => {
            const wt = WASTE_TYPES.find(w => w.id === l.wasteType);
            return (
              <div key={l.id} style={{ display: "flex", alignItems: "center", gap: 12, padding: "10px 14px", background: "white", borderRadius: 12, marginBottom: 8, border: "1px solid #eaf4eb" }}>
                <span style={{ fontSize: 22 }}>{wt?.icon}</span>
                <div style={{ flex: 1 }}>
                  <div style={{ fontSize: 13, fontWeight: 600, color: "#1a3d1f" }}>{wt?.label}</div>
                  <div style={{ fontSize: 11, color: "#7a9a7a" }}>{l.weightGrams}g</div>
                </div>
                <span style={{ fontSize: 13, fontWeight: 700, color: "#2d7a3a" }}>+{l.points} pts</span>
              </div>
            );
          })}
        </div>
      )}
    </div>
  );
}

