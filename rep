              <div className="progress-bar" style={{ marginBottom: 24 }}><div className="progress-fill" style={{ width: `${((quizIdx) / QUIZ_QUESTIONS.length) * 100}%` }} /></div>
              <div className="card" style={{ marginBottom: 20, background: "#eaf4eb", border: "1.5px solid #c5e0c5" }}>
                <div style={{ fontSize: 16, fontWeight: 700, color: "#1a3d1f", lineHeight: 1.4 }}>🤔 {QUIZ_QUESTIONS[quizIdx].q}</div>
              </div>
              {QUIZ_QUESTIONS[quizIdx].options.map((opt, i) => (
                <button key={i} className={`quiz-opt ${selected === null ? "" : i === QUIZ_QUESTIONS[quizIdx].answer ? "correct" : selected === i ? "wrong" : ""}`} onClick={() => answer(i)}>
                  <span style={{ marginRight: 10, fontWeight: 700 }}>{["A", "B", "C", "D"][i]}.</span> {opt}
                </button>
              ))}
            </div>
          ) : (
            <div style={{ textAlign: "center" }} className="slide-up">
              <div style={{ fontSize: 60, marginBottom: 16 }}>{score >= 4 ? "🏆" : score >= 3 ? "🎉" : "📚"}</div>
