  { id: "u1", name: "Priya Sharma", email: "priya@college.edu", points: 340, avatar: "PS", joined: "2025-01-15" },
  { id: "u2", name: "Arjun Mehta", email: "arjun@college.edu", points: 275, avatar: "AM", joined: "2025-01-20" },
  { id: "u3", name: "Sneha Nair", email: "sneha@college.edu", points: 210, avatar: "SN", joined: "2025-02-01" },
  { id: "u4", name: "Rahul Das", email: "rahul@college.edu", points: 190, avatar: "RD", joined: "2025-02-10" },
  { id: "u5", name: "Kavya Reddy", email: "kavya@college.edu", points: 155, avatar: "KR", joined: "2025-02-15" },
];

const INITIAL_LOGS = [
  { id: "l1", userId: "u1", wasteType: "dry", weightGrams: 800, points: 8, timestamp: new Date(Date.now() - 86400000 * 2).toISOString() },
  { id: "l2", userId: "u2", wasteType: "plastic", weightGrams: 1200, points: 12, timestamp: new Date(Date.now() - 86400000).toISOString() },
  { id: "l3", userId: "u1", wasteType: "wet", weightGrams: 2000, points: 20, timestamp: new Date(Date.now() - 86400000).toISOString() },
  { id: "l4", userId: "u3", wasteType: "dry", weightGrams: 500, points: 5, timestamp: new Date(Date.now() - 3600000 * 5).toISOString() },
];

const QUIZ_QUESTIONS = [
  { q: "Where does a banana peel go?", options: ["Dry Waste", "Wet Waste", "Plastic", "Hazardous"], answer: 1 },
  { q: "An empty plastic water bottle belongs in?", options: ["Wet Waste", "Hazardous", "Plastic", "Dry Waste"], answer: 2 },
  { q: "Old newspapers should go in?", options: ["Wet Waste", "Dry Waste", "Plastic", "Hazardous"], answer: 1 },
  { q: "Used cooking oil should be disposed as?", options: ["Wet Waste", "Dry Waste", "Plastic", "Hazardous"], answer: 3 },
  { q: "A dead battery belongs in?", options: ["Dry Waste", "Wet Waste", "Plastic", "Hazardous"], answer: 3 },
];

const AWARENESS_TIPS = [
  "Rinse plastic containers before recycling",
  "Don't mix food scraps with dry recyclables",
  "Crush plastic bottles to save bin space",
  "Remove labels from glass before recycling",
  "Compost wet waste when possible",
];

function getStorage(key, fallback) {
  try { const v = localStorage.getItem(key); return v ? JSON.parse(v) : fallback; } catch { return fallback; }
}
function setStorage(key, val) { try { localStorage.setItem(key, JSON.stringify(val)); } catch {} }

function genId() { return Math.random().toString(36).slice(2, 10); }

function todayStr() { return new Date().toISOString().slice(0, 10); }

function calcPoints(grams) { return Math.max(1, Math.floor((grams / 1000) * POINTS_PER_KG)); }

// ─── Main App ──────────────────────────────────────────────────────────────
export default function App() {
  const [users, setUsers] = useState(() => getStorage("swrs_users", INITIAL_USERS));
  const [logs, setLogs] = useState(() => getStorage("swrs_logs", INITIAL_LOGS));
  const [rewards, setRewards] = useState(() => getStorage("swrs_rewards", INITIAL_REWARDS));
  const [currentUser, setCurrentUser] = useState(() => getStorage("swrs_current", null));
  const [page, setPage] = useState("home");
  const [authMode, setAuthMode] = useState("login");
  const [toast, setToast] = useState(null);
  const [adminMode, setAdminMode] = useState(false);

  useEffect(() => { setStorage("swrs_users", users); }, [users]);
  useEffect(() => { setStorage("swrs_logs", logs); }, [logs]);
  useEffect(() => { setStorage("swrs_rewards", rewards); }, [rewards]);
  useEffect(() => { setStorage("swrs_current", currentUser); }, [currentUser]);

  const showToast = useCallback((msg, type = "success") => {
    setToast({ msg, type });
    setTimeout(() => setToast(null), 3500);
  }, []);

  const login = useCallback((email, password) => {
    const user = users.find(u => u.email === email);
    if (!user) { showToast("No account found. Please sign up.", "error"); return false; }
    setCurrentUser(user);
    showToast(`Welcome back, ${user.name.split(" ")[0]}! 🌱`);
    setPage("dispose");
    return true;
  }, [users, showToast]);

  const signup = useCallback((name, email) => {
    if (users.find(u => u.email === email)) { showToast("Email already registered.", "error"); return false; }
    const newUser = { id: genId(), name, email, points: 10, avatar: name.split(" ").map(w => w[0]).join("").slice(0,2).toUpperCase(), joined: new Date().toISOString().slice(0,10) };
    setUsers(u => [...u, newUser]);
    setCurrentUser(newUser);
    showToast(`Welcome to EcoRewards, ${name.split(" ")[0]}! You got 10 bonus points 🎉`);
    setPage("dispose");
    return true;
  }, [users, showToast]);

  const logout = useCallback(() => { setCurrentUser(null); setPage("home"); setAdminMode(false); }, []);

  const submitDisposal = useCallback((wasteType, weightGrams) => {
    if (!currentUser) return;
    const today = todayStr();
    const todayLogs = logs.filter(l => l.userId === currentUser.id && l.timestamp.startsWith(today));
    if (todayLogs.length >= MAX_DAILY_SUBMISSIONS) {
      showToast(`Daily limit of ${MAX_DAILY_SUBMISSIONS} submissions reached. Come back tomorrow!`, "error");
      return false;
    }
    if (weightGrams > MAX_WEIGHT_GRAMS) {
      showToast(`Maximum weight per entry is ${MAX_WEIGHT_GRAMS}g (${MAX_WEIGHT_GRAMS/1000}kg).`, "error");
      return false;
    }
    const points = calcPoints(weightGrams);
    const log = { id: genId(), userId: currentUser.id, wasteType, weightGrams, points, timestamp: new Date().toISOString() };
    setLogs(l => [log, ...l]);
    setUsers(us => us.map(u => u.id === currentUser.id ? { ...u, points: u.points + points } : u));
    setCurrentUser(cu => ({ ...cu, points: cu.points + points }));
    showToast(`+${points} points earned! Great job recycling! 🌿`);
    return true;
  }, [currentUser, logs, showToast]);

  const redeemReward = useCallback((reward) => {
    if (!currentUser) return;
    if (currentUser.points < reward.points) { showToast("Not enough points!", "error"); return; }
    setUsers(us => us.map(u => u.id === currentUser.id ? { ...u, points: u.points - reward.points } : u));
    setCurrentUser(cu => ({ ...cu, points: cu.points - reward.points }));
    setRewards(rs => rs.map(r => r.id === reward.id ? { ...r, stock: Math.max(0, r.stock - 1) } : r));
    showToast(`🎉 "${reward.name}" redeemed! Show this at the canteen.`);
  }, [currentUser, showToast]);

  const totalWaste = logs.reduce((s, l) => s + l.weightGrams, 0);
  const activeUsers = [...new Set(logs.map(l => l.userId))].length;

  const navItems = [
    { id: "home", label: "Home", icon: "🏠" },
    { id: "dispose", label: "Dispose", icon: "♻️" },
    { id: "rewards", label: "Rewards", icon: "🎁" },
    { id: "learn", label: "Learn", icon: "📚" },
    ...(currentUser ? [{ id: "profile", label: "Profile", icon: "👤" }] : []),
    ...(adminMode ? [{ id: "admin", label: "Admin", icon: "⚙️" }] : []),
  ];

  return (
    <div style={{ fontFamily: "'DM Sans', 'Segoe UI', sans-serif", background: "#f0f7f0", minHeight: "100vh", maxWidth: 480, margin: "0 auto", position: "relative", boxShadow: "0 0 40px rgba(0,0,0,0.08)" }}>
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Space+Grotesk:wght@500;700&display=swap');
        * { box-sizing: border-box; margin: 0; padding: 0; }
        input, select, textarea { font-family: inherit; }
        button { font-family: inherit; cursor: pointer; border: none; }
        ::-webkit-scrollbar { width: 4px; } ::-webkit-scrollbar-thumb { background: #b5d4b5; border-radius: 4px; }
        .nav-btn { background: none; padding: 8px 4px; display: flex; flex-direction: column; align-items: center; gap: 3px; font-size: 10px; color: #6b8c6b; transition: all 0.2s; border-radius: 8px; min-width: 52px; }
        .nav-btn.active { color: #2d7a3a; }
        .nav-btn .icon { font-size: 20px; }
        .eco-btn { background: #2d7a3a; color: white; padding: 14px 28px; border-radius: 50px; font-size: 15px; font-weight: 600; transition: all 0.2s; letter-spacing: 0.3px; }
        .eco-btn:hover { background: #235e2c; transform: translateY(-1px); box-shadow: 0 4px 16px rgba(45,122,58,0.35); }
        .eco-btn:active { transform: translateY(0); }
        .eco-btn.outline { background: transparent; border: 2px solid #2d7a3a; color: #2d7a3a; }
        .eco-btn.outline:hover { background: #2d7a3a; color: white; }
        .card { background: white; border-radius: 20px; padding: 20px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); }
        .tag { display: inline-block; padding: 3px 10px; border-radius: 50px; font-size: 11px; font-weight: 600; letter-spacing: 0.5px; text-transform: uppercase; }
        input[type="text"], input[type="email"], input[type="password"], input[type="number"], select {
          width: 100%; padding: 13px 16px; border: 1.5px solid #dde8dd; border-radius: 12px; font-size: 15px; background: #f8faf8; outline: none; transition: border 0.2s;
        }
        input:focus, select:focus { border-color: #2d7a3a; background: white; }
        .waste-chip { border: 2px solid transparent; border-radius: 16px; padding: 14px; cursor: pointer; transition: all 0.2s; background: #f8faf8; }
        .waste-chip.selected { border-color: #2d7a3a; background: #eaf4eb; }
        .pulse { animation: pulse 2s infinite; }
        @keyframes pulse { 0%,100%{box-shadow:0 0 0 0 rgba(45,122,58,0.4)} 50%{box-shadow:0 0 0 10px rgba(45,122,58,0)} }
        .slide-up { animation: slideUp 0.4s ease; }
        @keyframes slideUp { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:translateY(0)} }
        .badge-medal { display: inline-block; font-size: 20px; }
        .progress-bar { height: 8px; background: #e0ece0; border-radius: 50px; overflow: hidden; }
        .progress-fill { height: 100%; background: linear-gradient(90deg, #2d7a3a, #4caf50); border-radius: 50px; transition: width 0.8s ease; }
        .avatar { width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 13px; color: white; flex-shrink: 0; }
        .quiz-opt { padding: 12px 16px; border-radius: 12px; border: 2px solid #dde8dd; background: white; cursor: pointer; text-align: left; font-size: 14px; transition: all 0.2s; width: 100%; margin-bottom: 8px; font-family: inherit; }
        .quiz-opt:hover { border-color: #2d7a3a; background: #f0f8f0; }
        .quiz-opt.correct { border-color: #2d7a3a; background: #eaf4eb; color: #1a5c25; }
        .quiz-opt.wrong { border-color: #e24b4a; background: #fdf0f0; color: #a32d2d; }
        .leaderboard-row { display: flex; align-items: center; gap: 12px; padding: 12px 0; border-bottom: 1px solid #f0f5f0; }
        .leaderboard-row:last-child { border: none; }
        .stat-pill { background: #eaf4eb; color: #1a5c25; border-radius: 50px; padding: 6px 14px; font-size: 13px; font-weight: 600; }
      `}</style>

      {/* Header */}
      <div style={{ background: "white", padding: "16px 20px 12px", display: "flex", alignItems: "center", justifyContent: "space-between", position: "sticky", top: 0, zIndex: 100, borderBottom: "1px solid #eaf4eb" }}>
        <div style={{ display: "flex", alignItems: "center", gap: 10 }} onClick={() => setPage("home")} className="eco-logo" style={{ cursor: "pointer", display: "flex", alignItems: "center", gap: 10 }}>
          <div style={{ width: 36, height: 36, background: "#2d7a3a", borderRadius: 10, display: "flex", alignItems: "center", justifyContent: "center", fontSize: 18 }}>🌿</div>
          <span style={{ fontFamily: "'Space Grotesk', sans-serif", fontWeight: 700, fontSize: 18, color: "#1a3d1f" }}>EcoRewards</span>
        </div>
        <div style={{ display: "flex", alignItems: "center", gap: 10 }}>
          {currentUser ? (
            <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
              <span className="stat-pill">🌟 {currentUser.points} pts</span>
              <div className="avatar" style={{ background: "#2d7a3a", fontSize: 11, cursor: "pointer" }} onClick={() => setPage("profile")}>{currentUser.avatar}</div>
            </div>
          ) : (
            <button className="eco-btn" style={{ padding: "8px 18px", fontSize: 13 }} onClick={() => { setAuthMode("login"); setPage("auth"); }}>Sign In</button>
          )}
        </div>
      </div>

      {/* Page Content */}
      <div style={{ minHeight: "calc(100vh - 130px)", paddingBottom: 80 }}>
        {page === "home" && <HomePage setPage={setPage} setAuthMode={setAuthMode} currentUser={currentUser} users={users} logs={logs} totalWaste={totalWaste} activeUsers={activeUsers} setAdminMode={setAdminMode} adminMode={adminMode} />}
        {page === "auth" && <AuthPage mode={authMode} setMode={setAuthMode} login={login} signup={signup} setPage={setPage} />}
        {page === "dispose" && <DisposePage currentUser={currentUser} setPage={setPage} setAuthMode={setAuthMode} submitDisposal={submitDisposal} logs={logs} />}
        {page === "rewards" && <RewardsPage currentUser={currentUser} rewards={rewards} redeemReward={redeemReward} setPage={setPage} />}
        {page === "learn" && <LearnPage currentUser={currentUser} users={users} setUsers={setUsers} setCurrentUser={setCurrentUser} showToast={showToast} />}
        {page === "profile" && <ProfilePage currentUser={currentUser} users={users} logs={logs} logout={logout} setPage={setPage} />}
        {page === "admin" && adminMode && <AdminPage users={users} setUsers={setUsers} logs={logs} rewards={rewards} setRewards={setRewards} currentUser={currentUser} setCurrentUser={setCurrentUser} showToast={showToast} />}
      </div>

      {/* Bottom Nav */}
      <div style={{ position: "fixed", bottom: 0, left: "50%", transform: "translateX(-50%)", width: "100%", maxWidth: 480, background: "white", borderTop: "1px solid #eaf4eb", display: "flex", justifyContent: "space-around", padding: "8px 4px 12px", zIndex: 100 }}>
        {navItems.map(item => (
          <button key={item.id} className={`nav-btn ${page === item.id ? "active" : ""}`} onClick={() => setPage(item.id)}>
            <span className="icon">{item.icon}</span>
            <span style={{ fontWeight: page === item.id ? 600 : 400 }}>{item.label}</span>
          </button>
        ))}
        {!currentUser && (
          <button className="nav-btn" onClick={() => { setAuthMode("login"); setPage("auth"); }}>
            <span className="icon">🔑</span>
            <span>Login</span>
          </button>
        )}
        {currentUser && (
          <button className="nav-btn" onClick={logout}>
            <span className="icon">🚪</span>
            <span>Logout</span>
          </button>
        )}
      </div>

      {/* Toast */}
      {toast && (
        <div style={{ position: "fixed", top: 70, left: "50%", transform: "translateX(-50%)", background: toast.type === "error" ? "#e24b4a" : "#2d7a3a", color: "white", padding: "12px 20px", borderRadius: 50, fontSize: 14, fontWeight: 500, zIndex: 999, whiteSpace: "nowrap", maxWidth: "90vw", textAlign: "center", boxShadow: "0 4px 20px rgba(0,0,0,0.2)", animation: "slideUp 0.3s ease" }}>
          {toast.msg}
        </div>
      )}
    </div>
  );
}

// ─── HOME PAGE ─────────────────────────────────────────────────────────────
function HomePage({ setPage, setAuthMode, currentUser, users, logs, totalWaste, activeUsers, setAdminMode, adminMode }) {
  const sortedUsers = [...users].sort((a, b) => b.points - a.points).slice(0, 5);
  const medals = ["🥇", "🥈", "🥉", "4️⃣", "5️⃣"];
  const tips = AWARENESS_TIPS;
  const [tipIdx, setTipIdx] = useState(0);
  useEffect(() => { const t = setInterval(() => setTipIdx(i => (i + 1) % tips.length), 4000); return () => clearInterval(t); }, []);

  return (
    <div className="slide-up" style={{ padding: "0 16px" }}>
      {/* Hero */}
      <div style={{ background: "linear-gradient(135deg, #1a3d1f 0%, #2d7a3a 100%)", borderRadius: "0 0 32px 32px", margin: "0 -16px", padding: "36px 28px 40px", marginBottom: 24, position: "relative", overflow: "hidden" }}>
        <div style={{ position: "absolute", top: -20, right: -20, width: 120, height: 120, background: "rgba(255,255,255,0.05)", borderRadius: "50%" }} />
        <div style={{ position: "absolute", bottom: -30, left: -10, width: 100, height: 100, background: "rgba(255,255,255,0.04)", borderRadius: "50%" }} />
        <div style={{ fontSize: 11, fontWeight: 600, letterSpacing: 2, color: "#a8e6b0", marginBottom: 10, textTransform: "uppercase" }}>Smart Campus Initiative</div>
        <h1 style={{ fontFamily: "'Space Grotesk', sans-serif", fontSize: 26, fontWeight: 700, color: "white", lineHeight: 1.25, marginBottom: 16 }}>Earn Rewards for<br />Saving the Planet 🌍</h1>
        <p style={{ color: "#c5e8c8", fontSize: 14, lineHeight: 1.6, marginBottom: 24 }}>Scan any bin QR code, log your waste disposal, and earn points for eco-friendly actions on campus.</p>
        <div style={{ display: "flex", gap: 12 }}>
          {currentUser ? (
            <button className="eco-btn pulse" style={{ background: "white", color: "#2d7a3a", fontSize: 14 }} onClick={() => setPage("dispose")}>
              ♻️ Log Disposal
            </button>
          ) : (
            <button className="eco-btn pulse" style={{ background: "white", color: "#2d7a3a", fontSize: 14 }} onClick={() => { setAuthMode("signup"); setPage("auth"); }}>
              📱 Scan & Start
            </button>
          )}
          <button className="eco-btn outline" style={{ borderColor: "rgba(255,255,255,0.5)", color: "white", fontSize: 14 }} onClick={() => setPage("learn")}>
            Learn More
          </button>
        </div>
      </div>

      {/* Stats */}
      <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: 12, marginBottom: 24 }}>
        {[
          { label: "Waste Collected", value: `${(totalWaste / 1000).toFixed(1)}kg`, icon: "🗑️" },
          { label: "Active Users", value: activeUsers, icon: "👥" },
          { label: "Points Given", value: logs.reduce((s, l) => s + l.points, 0), icon: "⭐" },
        ].map(s => (
          <div key={s.label} className="card" style={{ textAlign: "center", padding: "16px 10px" }}>
            <div style={{ fontSize: 22, marginBottom: 6 }}>{s.icon}</div>
            <div style={{ fontSize: 18, fontWeight: 700, color: "#1a3d1f" }}>{s.value}</div>
            <div style={{ fontSize: 10, color: "#7a9a7a", fontWeight: 500, marginTop: 2 }}>{s.label}</div>
          </div>
        ))}
      </div>

      {/* Awareness Tip Ticker */}
      <div style={{ background: "#eaf4eb", borderRadius: 14, padding: "12px 16px", marginBottom: 24, display: "flex", alignItems: "center", gap: 10, border: "1px solid #c5e0c5" }}>
        <span style={{ fontSize: 20 }}>💡</span>
        <div>
          <div style={{ fontSize: 10, fontWeight: 700, color: "#2d7a3a", textTransform: "uppercase", letterSpacing: 1, marginBottom: 3 }}>Eco Tip</div>
          <div style={{ fontSize: 13, color: "#1a3d1f", fontWeight: 500 }}>{tips[tipIdx]}</div>
        </div>
      </div>

      {/* Leaderboard */}
      <div className="card" style={{ marginBottom: 24 }}>
        <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between", marginBottom: 16 }}>
          <h2 style={{ fontSize: 16, fontWeight: 700, color: "#1a3d1f" }}>🏆 Top Recyclers</h2>
          <span style={{ fontSize: 12, color: "#7a9a7a" }}>This Month</span>
        </div>
        {sortedUsers.map((u, i) => (
          <div key={u.id} className="leaderboard-row">
            <span style={{ fontSize: 20, minWidth: 28 }}>{medals[i]}</span>
            <div className="avatar" style={{ background: ["#2d7a3a","#4a90d9","#c8a87a","#9b59b6","#e67e22"][i], fontSize: 11 }}>{u.avatar}</div>
            <div style={{ flex: 1 }}>
              <div style={{ fontSize: 14, fontWeight: 600, color: "#1a3d1f" }}>{u.name}</div>
              <div style={{ fontSize: 11, color: "#7a9a7a" }}>{(users.find(x=>x.id===u.id) ? logs.filter(l=>l.userId===u.id).reduce((s,l)=>s+l.weightGrams,0)/1000 : 0).toFixed(1)} kg disposed</div>
            </div>
            <div style={{ textAlign: "right" }}>
              <div style={{ fontSize: 15, fontWeight: 700, color: "#2d7a3a" }}>{u.points}</div>
              <div style={{ fontSize: 10, color: "#7a9a7a" }}>pts</div>
            </div>
          </div>
        ))}
      </div>

      {/* Admin Access */}
      <div style={{ textAlign: "center", marginBottom: 12 }}>
        <button onClick={() => { setAdminMode(!adminMode); if (!adminMode) setPage("admin"); }} style={{ background: "none", color: "#aaa", fontSize: 11, padding: "6px 12px", borderRadius: 8, border: "1px solid #ddd" }}>
          {adminMode ? "🔒 Exit Admin" : "⚙️ Admin Access"}
        </button>
      </div>
    </div>
  );
}

// ─── AUTH PAGE ─────────────────────────────────────────────────────────────
function AuthPage({ mode, setMode, login, signup, setPage }) {
  const [name, setName] = useState("");
  const [email, setEmail] = useState("");
  const [password, setPassword] = useState("");

  const handleSubmit = () => {
    if (!email) return;
    if (mode === "login") login(email, password);
    else { if (!name) return; signup(name, email); }
  };

  const demoLogin = () => login("priya@college.edu", "password");

  return (
    <div className="slide-up" style={{ padding: "24px 16px" }}>
      <div style={{ textAlign: "center", marginBottom: 32 }}>
        <div style={{ fontSize: 48, marginBottom: 12 }}>🌿</div>
