}

// ─── LEARN PAGE ────────────────────────────────────────────────────────────
function LearnPage({ currentUser, users, setUsers, setCurrentUser, showToast }) {
  const [tab, setTab] = useState("guide");
  const [quizIdx, setQuizIdx] = useState(0);
  const [selected, setSelected] = useState(null);
  const [score, setScore] = useState(0);
  const [done, setDone] = useState(false);
  const [quizRewarded, setQuizRewarded] = useState(() => getStorage("swrs_quiz_done", false));

  const answer = (idx) => {
    if (selected !== null) return;
    setSelected(idx);
    if (idx === QUIZ_QUESTIONS[quizIdx].answer) setScore(s => s + 1);
    setTimeout(() => {
      if (quizIdx + 1 >= QUIZ_QUESTIONS.length) setDone(true);
      else { setQuizIdx(i => i + 1); setSelected(null); }
    }, 1200);
  };

  const finishQuiz = () => {
    if (!quizRewarded && currentUser && score >= 3) {
      setUsers(us => us.map(u => u.id === currentUser.id ? { ...u, points: u.points + 5 } : u));
      setCurrentUser(cu => ({ ...cu, points: cu.points + 5 }));
      setQuizRewarded(true);
      setStorage("swrs_quiz_done", true);
      showToast("🎉 +5 bonus points for acing the quiz!");
    }
    setDone(true);
  };

  const tabs = [
    { id: "guide", label: "📖 Guide" },
    { id: "quiz", label: "🧠 Quiz" },
    { id: "impact", label: "🌍 Impact" },
  ];

  return (
    <div className="slide-up" style={{ padding: "20px 16px" }}>
      <h2 style={{ fontFamily: "'Space Grotesk', sans-serif", fontSize: 22, fontWeight: 700, color: "#1a3d1f", marginBottom: 4 }}>Learn & Earn 📚</h2>
      <p style={{ color: "#7a9a7a", fontSize: 13, marginBottom: 20 }}>Master waste segregation. Complete the quiz for bonus points!</p>

      <div style={{ display: "flex", gap: 8, marginBottom: 24, background: "white", padding: "6px", borderRadius: 16 }}>
        {tabs.map(t => (
          <button key={t.id} onClick={() => setTab(t.id)} style={{ flex: 1, padding: "8px 0", borderRadius: 10, background: tab === t.id ? "#2d7a3a" : "transparent", color: tab === t.id ? "white" : "#7a9a7a", border: "none", fontSize: 12, fontWeight: 700, cursor: "pointer" }}>{t.label}</button>
        ))}
      </div>

      {/* GUIDE TAB */}
      {tab === "guide" && (
        <div>
          {[
            { icon: "📄", color: "#fff8e8", accent: "#c8a87a", title: "Dry Waste", items: ["Paper & cardboard", "Metal cans & foil", "Glass bottles", "Fabric & leather", "Electronic waste"], tip: "Keep dry waste clean and separate from food residue." },
            { icon: "🥬", color: "#eaf4eb", accent: "#2d7a3a", title: "Wet Waste", items: ["Food scraps & peels", "Cooked leftovers", "Tea bags & coffee grounds", "Garden waste", "Egg shells"], tip: "Wet waste can be composted to enrich soil naturally." },
            { icon: "♻️", color: "#e8f4fb", accent: "#4a90d9", title: "Plastic Waste", items: ["Water & beverage bottles", "Plastic bags", "Packaging materials", "Straws & cups", "Plastic containers"], tip: "Rinse and crush plastic before disposal to save space." },
            { icon: "⚠️", color: "#fff0f0", accent: "#e24b4a", title: "Hazardous Waste", items: ["Batteries & electronics", "Chemicals & solvents", "Medicines & syringes", "Paint & aerosols", "Fluorescent bulbs"], tip: "Never mix hazardous waste with regular bins. Use designated collection points." },
          ].map(wt => (
            <div key={wt.title} className="card" style={{ marginBottom: 16, background: wt.color, border: `1.5px solid ${wt.accent}30` }}>
              <div style={{ display: "flex", alignItems: "center", gap: 12, marginBottom: 12 }}>
                <div style={{ width: 48, height: 48, background: "white", borderRadius: 14, display: "flex", alignItems: "center", justifyContent: "center", fontSize: 26 }}>{wt.icon}</div>
                <div>
                  <div style={{ fontSize: 16, fontWeight: 700, color: "#1a3d1f" }}>{wt.title}</div>
                  <div style={{ fontSize: 11, color: wt.accent, fontWeight: 600 }}>TAP TO EXPAND</div>
                </div>
