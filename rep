              <div style={{ background: "rgba(255,255,255,0.8)", borderRadius: 10, padding: "8px 12px", display: "flex", gap: 8, alignItems: "flex-start" }}>
                <span>💡</span>
                <span style={{ fontSize: 12, color: "#3a5a3a", lineHeight: 1.5 }}>{wt.tip}</span>
              </div>
            </div>
          ))}

          {/* Tips Grid */}
          <div className="card">
            <h3 style={{ fontSize: 14, fontWeight: 700, color: "#1a3d1f", marginBottom: 14 }}>🌟 Quick Tips</h3>
